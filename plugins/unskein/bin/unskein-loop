#!/usr/bin/env python3
"""unskein-loop — run_loop.py main() 진입 래퍼.

run_loop.py 는 `import run_once` / `from run_once import _post, process_task`
로 형제 모듈을 참조하고, 모듈 로드 시점에 env(UNSKEIN_LOOP_INTERVAL 등)와
argv 를 읽는다. 따라서 orchestrator 디렉토리를 sys.path 에 넣어 run_loop 를
일반 모듈로 import 한 뒤 main() 을 호출한다.
"""
import os
import sys

plugin_root = os.environ.get(
    "CLAUDE_PLUGIN_ROOT",
    os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
)
sys.path.insert(0, os.path.join(plugin_root, "orchestrator"))

from run_loop import main

if __name__ == "__main__":
    sys.exit(main())
