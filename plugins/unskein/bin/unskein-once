#!/usr/bin/env python3
"""unskein-once — run_once.py main() 진입 래퍼.

orchestrator 디렉토리를 sys.path 에 넣어 run_once 모듈을 직접 import 한다.
(run_loop.py 가 `import run_once` 로 형제 모듈을 참조하므로 unskein-loop 와
같은 path 처리 방식을 맞춘다.)
"""
import os
import sys

plugin_root = os.environ.get(
    "CLAUDE_PLUGIN_ROOT",
    os.path.dirname(os.path.dirname(os.path.abspath(__file__))),
)
sys.path.insert(0, os.path.join(plugin_root, "orchestrator"))

from run_once import main

if __name__ == "__main__":
    sys.exit(main())
