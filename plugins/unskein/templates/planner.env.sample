# ── UnSkein PLANNER 인증 (역할: 운영자/플래너) — 샘플 템플릿 (ADR-0013 · ADR-0021) ──
# 이 파일은 커밋되는 "비밀 없는" 템플릿이다. 실제 설정은 아래처럼 복사·편집한다.
# 이름은 역할 기반: executor.env(EXECUTOR) 와 짝.
#
# PLANNER = 스코프·등록 Claude Code 세션. 개발은 안 하므로 모리 토큰·git creds·
# work root 는 불필요 — 서버(UNSKEIN_API) + 플래너 토큰 둘뿐이다.
#
# 🔑 각 값은 **export** — source 하면 그대로 자식(claude→스킬 curl)에 상속된다.
#    (export 없는 KEY=VALUE 는 셸 변수라 자식에 안 간다. 스킬의 인증 로드
#     `bin/planner-env.sh` 는 set -a 로 읽어 export 없이도 복구하지만, 명시적
#     `source planner.env && claude` 로 쓰려면 export 가 있어야 안전하다.)

# ── 상태 루트 (여러 프로젝트를 한 플래너로 다룰 때 — 프로젝트별 격리, ADR-0021) ──
# 기획자는 보통 여러 프로젝트를 동시에 다룬다. 프로젝트마다 이 파일을 그 프로젝트
# 옆에 두면 토큰·서버가 안 섞인다. 배치(택1):
#
#   A. 단일/전역 (기본):        cp <이 파일> ~/.unskein/planner.env
#   B. 프로젝트별 (권장·다중):  cp <이 파일> <프로젝트작업폴더>/.unskein/planner.env
#                                (코드베이스 repo **밖**에 둔다 — 커밋·git clean 에 안 섞이게)
#   두 경우 모두:  chmod 600 <그 planner.env>   (# ~/.unskein·.unskein 은 repo 밖)
#
# 프로젝트별(B)이면 아래 한 줄로 상태 루트를 절대경로로 못박는다(자기완결 — 어느 cwd 에서
# source 해도 이 홈으로 확정). ~ 축약·상대경로 금지. 단일/전역(A)이면 이 줄은 비운다.
#export UNSKEIN_HOME=/home/<user>/<프로젝트작업폴더>/.unskein

# 등록 대상 서버 (테스트 서버 / 로컬 도그푸드 중 하나 — 프로젝트마다 다를 수 있다)
export UNSKEIN_API=https://unskein.mupai.studio
#export UNSKEIN_API=http://localhost:8200

# PLANNER 토큰 — 위 서버 설정 화면에서 kind=planner 로 발급한 개인 토큰.
# 등록 라우트(businesses·projects·tasks·plan)를 X-Planner-Token 으로 인가한다.
# ⚠️ 모리 토큰(EXECUTOR, kind=mori)과 다른 토큰. 섞으면 401. 프로젝트별(B)이면 프로젝트마다 전용 발급.
export UNSKEIN_PLANNER_TOKEN=

# 문서 PR용 GitHub 인증은 `gh auth` 가 담당 — 이 파일에 넣지 않는다.

# ── 사용법 (source 로 활성화) ──
# 스킬(unskein-scope·wbs·drawio·doctor)은 서버 호출 전에 인증을 자동 로드한다
#   (bin/planner-env.sh):  ① 셸 env → ② $UNSKEIN_HOME/planner.env → ③ cwd 에서 위로
#   첫 .unskein/planner.env → ④ 전역 ~/.unskein/planner.env.
# 그래서 두 가지로 쓴다:
#   (권장·명시) 프로젝트 코드베이스에서 실행 전에 source 한다 — 실행기와 같은 원칙:
#       cd <코드베이스>  &&  source <프로젝트작업폴더>/.unskein/planner.env  &&  claude
#   (폴백·자동) source 를 깜빡해도, 코드베이스가 그 .unskein 아래(하위)면 스킬이 cwd
#       에서 위로 올라가 planner.env 를 자동으로 찾는다.
# ⚠️ cwd 폴백 함정: 프로젝트 폴더를 서로 중첩하면 조상의 .unskein 을 주울 수 있다.
#    프로젝트끼리 겹치지 않게 두고, 확실히 하려면 명시적 source 를 쓴다. 진단은
#    doctor 가 UNSKEIN_PLANNER_ENV_FILE(어느 파일에서 로드됐나)로 확인해 준다.
