# ── UnSkein PLANNER 인증 (역할: 운영자/플래너) — 샘플 템플릿 (ADR-0013 · ADR-0021 · ADR-0022) ──
# 이 파일은 커밋되는 "비밀 없는" 템플릿이다. 실제 설정은 아래처럼 복사·편집한다.
# 이름은 역할 기반: executor.env(EXECUTOR) 와 짝.
#
# PLANNER = 스코프·등록 Claude Code 세션. 개발(claim)은 안 한다. 필요한 건 서버·토큰
# (등록)과, 그 프로젝트 코드베이스를 스스로 clone/pull 하기 위한 식별 정보 + git 키다.
#
# 🔑 프로젝트별 격리 전용(ADR-0021·0022). 기획자는 늘 여러 프로젝트를 동시에 다루므로,
#    프로젝트마다 이 파일을 그 프로젝트 옆(코드베이스 repo **밖**)에 두고 그 프로젝트에서
#    claude 를 띄우면 그 서버·토큰·코드베이스로 붙는다. 전역 한 벌(구 "방식 A")은 폐기.
#
# 🔑 각 값은 **export** — source 하면 그대로 자식(claude→스킬 curl·git)에 상속된다.
#    (export 없는 KEY=VALUE 는 셸 변수라 자식에 안 간다. 스킬의 인증 로드
#     `bin/planner-env.sh` 는 set -a 로 읽어 export 없이도 복구하지만, 명시적
#     `source planner.env && claude` 로 쓰려면 export 가 있어야 안전하다.)

# ── 배치 (프로젝트별 격리) ──
#   cp <이 파일> <프로젝트작업폴더>/.unskein/planner.env   # 코드베이스 repo 밖(그 아래에 clone 됨)
#   chmod 600 <그 planner.env>
#
# 아래 UNSKEIN_HOME 한 줄로 상태 루트를 절대경로로 못박는다(자기완결 — 어느 cwd 에서 source
# 해도 이 홈으로 확정). ~ 축약·상대경로 금지. 코드베이스는 이 홈의 **부모** 아래로 clone 된다
# (예: HOME=/home/u/work/frameweb/.unskein → 코드베이스=/home/u/work/frameweb/<repo>).
export UNSKEIN_HOME="/home/<user>/<프로젝트작업폴더>/.unskein"

# 등록 대상 서버 (테스트 서버 / 로컬 도그푸드 중 하나 — 프로젝트마다 다를 수 있다)
export UNSKEIN_API=https://unskein.mupai.studio
#export UNSKEIN_API=http://localhost:8200

# PLANNER 토큰 — 위 서버 설정 화면에서 kind=planner 로 발급한 개인 토큰.
# 등록 라우트(businesses·projects·tasks·plan)를 X-Planner-Token 으로 인가한다.
# ⚠️ 모리 토큰(EXECUTOR, kind=mori)과 다른 토큰. 섞으면 401. 프로젝트마다 전용 발급.
export UNSKEIN_PLANNER_TOKEN=

# ── 대상 프로젝트 식별 (repo_url 조회 → unskein-scope 자동 clone/pull, ADR-0022) ──
# 플래너 토큰은 유저(멤버십)까지만 특정하지 어느 프로젝트인지는 못 짚는다. 코드베이스가
# 아직 없을 땐 git remote 로도 알 수 없으므로, 비즈니스·프로젝트 이름을 여기 명시한다.
# unskein-scope 가 이 이름으로 서버에서 repo_url 을 조회해(GET /api/businesses →
# GET /api/businesses/{id}/projects, X-Planner-Token) 코드베이스를 보장한다:
#   없으면 clone, 있으면 git pull --ff-only. 이름은 서버 표기와 정확히 일치해야 한다.
#   ⚠️ **반드시 따옴표** — 이름에 공백이 흔하다(예: "MUPAI STUDIO"). 따옴표 없으면 첫 공백에서 잘려 조회 실패.
export UNSKEIN_BUSINESS="<비즈니스 이름>"
export UNSKEIN_PROJECT="<프로젝트 이름>"

# ── git 키 (코드베이스 clone/pull·문서 PR push) ──
# unskein-scope 가 clone/pull 할 때 GIT_SSH_COMMAND="ssh -i $UNSKEIN_SSH_KEY -o IdentitiesOnly=yes"
# 로 이 키를 쓴다. 실행기와 **같은 변수명**(EXECUTOR 도 UNSKEIN_SSH_KEY 로 SSH repo 를 붙는다).
# 키는 상태 루트 밖·권한 600. 표준 위치를 권장: <상태루트>/creds/id_ed25519.
#   ssh-keygen -t ed25519 -f "$UNSKEIN_HOME/creds/id_ed25519" -N ""   # .pub 을 GitHub 에 등록
# HTTPS repo 로 붙는다면 SSH 대신 gh 자격(`gh auth setup-git`)에 맡기고 이 줄은 비운다.
export UNSKEIN_SSH_KEY="${UNSKEIN_HOME}/creds/id_ed25519"

# 문서 PR용 GitHub 인증(gh pr create)은 `gh auth` 가 담당 — 이 파일에 넣지 않는다.

# ── 사용법 (source 로 활성화) ──
# 스킬(unskein-scope·wbs·drawio·doctor)은 서버 호출 전에 인증을 자동 로드한다
#   (bin/planner-env.sh):  ① 셸 env → ② $UNSKEIN_HOME/planner.env → ③ cwd 에서 위로
#   첫 .unskein/planner.env → ④ 전역 ~/.unskein/planner.env(하위호환).
# 두 가지로 쓴다:
#   (권장·명시) 프로젝트 작업폴더에서 실행 전에 source 한다:
#       source <프로젝트작업폴더>/.unskein/planner.env  &&  claude
#       (코드베이스가 아직 없어도 된다 — unskein-scope 가 첫 clone 을 한다.)
#   (폴백·자동) source 를 깜빡해도, cwd 가 그 .unskein 아래면 스킬이 위로 올라가 찾는다.
# ⚠️ cwd 폴백 함정: 프로젝트 폴더를 서로 중첩하거나 전역 ~/.unskein 이 남아 있으면 조상의
#    .unskein 을 주울 수 있다. 프로젝트끼리 겹치지 말고, 전역 ~/.unskein 은 무력화(mv
#    ~/.unskein ~/.unskein_back)하며, 확실히 하려면 명시적 source 를 쓴다. 진단은 doctor 가
#    UNSKEIN_PLANNER_ENV_FILE(어느 파일에서 로드됐나)로 확인해 준다.
