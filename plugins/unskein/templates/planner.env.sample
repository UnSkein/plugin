# ── UnSkein PLANNER 인증 (역할: 운영자/플래너) — 샘플 템플릿 (ADR-0013) ──
# 이 파일은 커밋되는 "비밀 없는" 템플릿이다. 실제 설정은:
#   cp <이 파일> ~/.unskein/planner.env  &&  chmod 600 ~/.unskein/planner.env
# 로 복사한 뒤 아래 빈 값(토큰)을 채운다. (~/.unskein 은 repo 밖 → 커밋에 안 섞임)
#
# PLANNER = 스코프·등록 Claude Code 세션. 개발은 안 하므로 모리 토큰·git creds·
# work root 는 불필요. 사용: 등록 전  →  source ~/.unskein/planner.env

# 등록 대상 서버 (테스트 서버 / 로컬 도그푸드 중 하나)
UNSKEIN_API=https://unskein.mupai.studio
#UNSKEIN_API=http://localhost:8200

# PLANNER 토큰 — 서버 설정 화면에서 kind=planner 로 발급한 개인 토큰.
# admin 등록 라우트(businesses·projects·tasks·plan)를 X-Planner-Token 으로 인가한다.
# ⚠️ 모리 토큰(EXECUTOR, kind=mori)과 다른 토큰. 섞지 말 것.
UNSKEIN_PLANNER_TOKEN=

# 문서 PR용 GitHub 인증은 `gh auth` 가 담당 — 이 파일에 넣지 않는다.
