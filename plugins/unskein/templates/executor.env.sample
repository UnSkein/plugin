# ── UnSkein EXECUTOR 인증·구동 (역할: 모리 실행기) — 샘플 템플릿 (ADR-0013) ──
# 이 파일은 커밋되는 "비밀 없는" 템플릿이다. 실제 설정은 타겟별로:
#   cp <이 파일> ~/.unskein/env.test   &&  chmod 600 ~/.unskein/env.test   # 테스트 서버
#   cp <이 파일> ~/.unskein/env.local  &&  chmod 600 ~/.unskein/env.local  # 로컬 도그푸드
# 로 복사한 뒤 그 타겟의 API+토큰을 채운다. (~/.unskein 은 repo 밖 → 커밋에 안 섞임)
#
# 사용: watch/run 전  →  source ~/.unskein/env.<target>
# 주의: API 와 토큰은 한 서버에 묶인 짝. 한 번에 하나의 타겟만 source.

# 작업 큐 서버 (이 파일이 어느 타겟인지에 맞춘다)
UNSKEIN_API=https://unskein.mupai.studio
#UNSKEIN_API=http://localhost:8200

# 모리 토큰 — 위 서버 설정 화면에서 kind=mori 로 발급한 개인 토큰.
# X-Mori-Token 헤더로 /api/mori/* (claim·report·answer) 만 인가한다.
# ⚠️ PLANNER 토큰(kind=planner)과 다른 토큰.
UNSKEIN_MORI_TOKEN=

# (선택) 이 클라이언트가 바라볼 대상 — 비우면 토큰 사용자의 전체
#UNSKEIN_WATCH_BUSINESS=MUPAI STUDIO
#UNSKEIN_WATCH_PROJECT=UNSKEIN_SAAS

# (선택) 튜닝 — 기본값이 있어 안 적어도 됨
#UNSKEIN_MAX_CONCURRENCY=3
#UNSKEIN_LOOP_INTERVAL=30
#UNSKEIN_CLAUDE_TIMEOUT=600
#UNSKEIN_HEARTBEAT_INTERVAL=60

# git 클론 토큰은 별도 파일(~/.unskein/creds/.env)의 UNSKEIN_GIT_TOKEN 에 둔다
# (unskein-add-site 가 배치). SSH repo 면 ~/.unskein/creds/id_ed25519(권한 600).
