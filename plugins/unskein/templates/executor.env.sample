# ── UnSkein EXECUTOR 인증·구동 (역할: 모리 실행기) — 샘플 템플릿 (ADR-0013) ──
# 이 파일은 커밋되는 "비밀 없는" 템플릿이다. 실제 설정은:
#   cp <이 파일> ~/.unskein/executor.env   &&  chmod 600 ~/.unskein/executor.env
# 로 복사한 뒤 API+토큰을 채운다. (~/.unskein 은 repo 밖 → 커밋에 안 섞임)
# 이름은 역할 기반: ~/.unskein/planner.env(PLANNER) 와 짝. (".test" 아님 — 혼동 방지)
# 여러 서버를 오가면 executor.local.env 등으로 파일만 나눠 그 하나만 source (드묾).
#
# 사용: watch/run 전  →  source ~/.unskein/executor.env
# 주의: API 와 토큰은 한 서버에 묶인 짝. 한 번에 하나의 타겟만 source.
# 이 파일 하나가 이 실행기의 모든 인증을 담는다: 서버(모리) · git(clone/push·PR) · (선택)Anthropic · (선택)sudo.
#
# 🔑 각 값은 **export** — source 하면 그대로 자식(claude→run_once→다오)에 상속된다.
#    (export 없는 KEY=VALUE 는 셸 변수라 자식에 안 감. run_once 는 os.getenv 로 읽는다.)
# 매 셸 자동 로드하려면 ~/.bashrc 에:  [ -f ~/.unskein/executor.env ] && . ~/.unskein/executor.env

# 작업 큐 서버 (이 파일이 어느 타겟인지에 맞춘다)
export UNSKEIN_API=https://unskein.mupai.studio
#export UNSKEIN_API=http://localhost:8200

# 모리 토큰 — 위 서버 설정 화면에서 kind=mori 로 발급한 개인 토큰.
# X-Mori-Token 헤더로 /api/mori/* (claim·report·answer) 만 인가한다.
# ⚠️ PLANNER 토큰(kind=planner)과 다른 토큰.
export UNSKEIN_MORI_TOKEN=

# (선택) 이 클라이언트가 바라볼 대상 — 비우면 토큰 사용자의 전체
# 공백이 든 값은 따옴표 필수 (없으면 source 가 깨진다)
#export UNSKEIN_WATCH_BUSINESS="MUPAI STUDIO"
#export UNSKEIN_WATCH_PROJECT="UNSKEIN_SAAS"

# (선택) 튜닝 — 기본값이 있어 안 적어도 됨
#export UNSKEIN_MAX_CONCURRENCY=3
#export UNSKEIN_LOOP_INTERVAL=30
#export UNSKEIN_CLAUDE_TIMEOUT=600
#export UNSKEIN_HEARTBEAT_INTERVAL=60

# ── git 인증 (HTTPS repo) — 이 파일 하나로 clone/push + PR ──
# clone/push: 오케스트레이터 askpass 가 UNSKEIN_GIT_TOKEN 을 쓴다 (env 가 creds/.env 보다 우선).
#export UNSKEIN_GIT_TOKEN=
# gh pr create: gh 가 GH_TOKEN 을 읽는다 — 위 토큰과 같은 PAT 재사용 가능.
#   GH_TOKEN 을 채우면 gh auth login·setup-git 을 생략할 수 있다.
#export GH_TOKEN=
# 여러 호스트면:  #export UNSKEIN_GIT_TOKEN_GITHUB_COM=   #export UNSKEIN_GIT_TOKEN_GITLAB_COM=
# SSH repo 면 위 둘 대신 키 '경로'만 (내용은 파일 ~/.unskein/creds/id_ed25519, 권한 600):
#export UNSKEIN_SSH_KEY=/home/<user>/.unskein/creds/id_ed25519

# (선택) Anthropic — 채우면 다오 claude 로그인 생략(단 API 과금). 비우면 claude 로그인 사용.
#export ANTHROPIC_API_KEY=

# (선택) 초기 프로비저닝 sudo — run_once·다오는 안 읽음 (build_git_env 가 다오 env 에서 strip).
#   셋업 스킬만 sudo -S 로 사용. NOPASSWD sudoers 면 불필요. 셋업 후 제거 권장.
#export UNSKEIN_SUDO_PASSWORD=
